# Neon read-only connection string for the SIG de suelo.
# Project: rough-darkness-29646026 · database: verceldb
# Role: web_readonly (SELECT only). Server-side ONLY — never expose with a
# NEXT_PUBLIC_ prefix. Set the real value in .env.local (gitignored) and in
# Vercel → Environment Variables.
NEON_DATABASE_URL=postgresql://web_readonly:********@<host>.neon.tech/verceldb?sslmode=require&channel_binding=require
