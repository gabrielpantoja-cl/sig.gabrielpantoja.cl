{
  "name": "sig-suelo",
  "version": "0.1.0",
  "description": "Single-page Next.js 16 SIG: mapa interactivo de transacciones CBR de suelo rural (centro-sur de Chile) sobre capas temáticas oficiales (áreas protegidas, límite urbano, DPA, red caminera MOP, catastro frutícola CIREN, suelos agrológicos). Stack: React 19, Leaflet + MarkerCluster, Neon Postgres read-only, Tailwind v4. Deploy: Vercel.",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Gabriel Pantoja",
    "url": "https://gabrielpantoja.cl"
  },
  "homepage": "https://sig.gabrielpantoja.cl",
  "bugs": {
    "url": "https://github.com/gabrielpantoja-cl/sig.gabrielpantoja.cl/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielpantoja-cl/sig.gabrielpantoja.cl.git"
  },
  "keywords": [
    "gis",
    "sig",
    "leaflet",
    "nextjs",
    "react",
    "chile",
    "cbr",
    "conservador-bienes-raices",
    "tasaciones",
    "eco-informatica",
    "open-data",
    "datos-abiertos",
    "geojson",
    "areas-protegidas",
    "neon-postgres"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "data:build:protected": "node scripts/build-protected-areas.mjs",
    "data:build:urban": "node scripts/build-urban-limit.mjs",
    "data:build:comunas": "node scripts/build-comunas.mjs",
    "data:build:red-vial": "node scripts/build-red-vial.mjs",
    "data:build:catastro-fruticola": "node scripts/build-catastro-fruticola.mjs",
    "data:build": "npm run data:build:protected && npm run data:build:urban && npm run data:build:comunas && npm run data:build:red-vial && npm run data:build:catastro-fruticola"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tmcw/togeojson": "^7.1.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "mapshaper": "^0.7.33",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
