# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local scratch dropped in the repo root: screenshots + DNS zone exports
# (scoped to root with a leading slash so public/ images stay tracked)
/*.png
/*.txt

# ETL cache — raw official datasets downloaded by scripts/ (not versioned;
# only the simplified output in public/data/ is committed)
/scripts/.cache/

# local agent overrides (per-machine, not shared)
CLAUDE.local.md

