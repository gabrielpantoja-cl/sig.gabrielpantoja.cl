{
  "$schema": "https://opencode.ai/config.json",

  // Per-developer settings (model, providers, MCP servers, permissions) are
  // intentionally NOT committed. Put them in `opencode.local.json` (gitignored)
  // or in your `~/.config/opencode/opencode.json`. See AGENTS.md § AI tooling
  // for the per-machine override convention.

  // Auto-discover the canonical agent instructions in this repo.
  "instructions": ["AGENTS.md", "AGENTS.local.md"],

  // Sharing stays manual (OpenCode default) so no session is auto-uploaded.
  // Snapshots stay enabled (the repo is small).
  "share": "manual",
  "snapshot": true
}